#!/usr/bin/env bash
#
# post-receive — Remote hook, runs after refs are updated.
#
# Checks out the latest commit into the worktree, then calls
# the deploy hook to run deployment scripts.
#
# GIT_DIR is set by git to the bare repo path.

set -euo pipefail

GIT_DIR="${GIT_DIR:-.}"
GIT_DIR=$(cd "$GIT_DIR" && pwd)

BONES_TOML="$GIT_DIR/bones/bones.toml"
HOOKS_DIR="$GIT_DIR/hooks"

# Read worktree and branch from bones.toml
WORKTREE=$(grep -E '^worktree\s*=' "$BONES_TOML" | head -1 | sed 's/.*=\s*"\(.*\)"/\1/')
BRANCH=$(grep -E '^branch\s*=' "$BONES_TOML" | head -1 | sed 's/.*=\s*"\(.*\)"/\1/')

if [ -z "$WORKTREE" ] || [ -z "$BRANCH" ]; then
    echo "[gitbones] Error: Could not read worktree or branch from $BONES_TOML"
    exit 1
fi

echo "[gitbones] Checking out $BRANCH to $WORKTREE..."

git --work-tree="$WORKTREE" --git-dir="$GIT_DIR" checkout -f "$BRANCH"

echo "[gitbones] Checkout complete. Running deploy..."

exec "$HOOKS_DIR/deploy"
